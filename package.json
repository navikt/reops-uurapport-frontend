{
  "name": "reops-uurapport-frontend",
  "version": "0.0.1",
  "scripts": {
    "mock-dev": "concurrently \"pnpm run mock\" \"pnpm run dev:mock\"",
    "dev": "APP_ENV=local VITE_APP_ENV=local next dev",
    "dev:mock": "APP_ENV=mock VITE_APP_ENV=mock next dev",
    "prettier": "prettier --write .",
    "start": "next start",
    "build": "next build",
    "mock": "tsx mock/server.ts",
    "lint": "eslint .",
    "knip": "knip",
    "knip:production": "knip --production",
    "prepare": "husky",
    "analyze": "ANALYZE=true next build -c next.config.analyze.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@navikt/aksel-icons": "8.15.0",
    "@navikt/ds-css": "8.15.0",
    "@navikt/ds-react": "8.15.0",
    "@navikt/oasis": "4.1.4",
    "lodash": "^4.18.1",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.2",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@hono/node-server": "2.0.10",
    "@next/bundle-analyzer": "^16.2.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "hono": "4.12.31",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,json,css,scss,md}": "prettier --write"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
